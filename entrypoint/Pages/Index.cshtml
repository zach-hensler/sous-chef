@page
@model IndexModel
@{
    ViewData["Title"] = "Recipes";
}

<div>
    <h1>Recipes</h1>
    @if (Model.Error != null) {
        <div>
            <p>An error occured while fetching recipes.</p>
            <p>@Model.Error.Value.Item1 - @Model.Error.Value.Item2</p>
        </div>
    }
    else if (Model.RecipeData != null) {
        <div class="recipe-list-container">
            @foreach (var recipe in Model.RecipeData.Items) {
                <div class="recipe-list-container">
                    <hr />
                    <div class="recipe-list-header">
                        <h2 class="recipe-list-header-name">
                            <a asp-page="/Recipe" asp-route-id="@recipe.Id">@recipe.Name</a>
                        </h2>
                        <div class="recipe-list-chip-container">
                            <p class="recipe-list-chip">@recipe.EffortLevel</p>
                            <p class="recipe-list-chip">@recipe.Category</p>
                        </div>
                    </div>
                    <p>@recipe.Description</p>
                </div>
            }
        </div>
    }
    else {
        <div>
            <p>An unexpected error occured while fetching recipes.</p>
        </div>
    }
</div>
