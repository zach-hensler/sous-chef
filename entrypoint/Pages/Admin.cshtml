@page
@model AdminModel

<div>
    <h1>Admin Panel</h1>
    <h2>Actions</h2>
    <form method="post">
        <input
            formaction="Admin?@AdminActions.Migrate"
            type="submit"
            value="Migrate"/>
    </form>
    <h2>Error History</h2>
    @if (Model.ErrorRes == null) {
        <p>Unable to load Errors</p>
    }
    else if (Model.ErrorRes.Total == 0) {
        <p>No errors were found!</p>
    }
    else {
        foreach (var errors in Model.ErrorRes.Errors) {
            <div>
                <hr />
                <h3>@errors.source - @errors.occurred_at</h3>
                <p>@errors.message</p>
            </div>
        }
    }
</div>