@page "{wishlistId:int}"
@model WishlistEditModal

<div>
    @if (Model.Item == null) {
        <p>Unable to load wishlist item '@Model.Id'</p>
    }
    else {
        <h2>@Model.Item.Name</h2>
        <p>Added on @ViewUtils.FormatDate(Model.Item.CreatedAt)</p>
        <form method="post">
            <label for="ref">Reference</label>
            <input id="ref" asp-for="@Model.Item.Reference" />
            <label for="priority">Priority</label>
            <input id="priority" asp-for="@Model.Item.Priority" step="1" type="number"/>
            <label for="completed">Completed</label>
            <input id="completed" asp-for="@Model.Item.Completed" type="checkbox" />
            <hr />
            <button class="primary">Save</button>
        </form>
    }
</div>