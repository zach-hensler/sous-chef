@page
@model AdminModel

<div>
    <h1>Admin Panel</h1>
    <h2>Actions</h2>
    @Html.AntiForgeryToken()
    <div id="@ViewIds.AdminMigrateButtonWrapper">
        @await Html.PartialAsync("_AdminMigrateButton", Model)
    </div>
    <h2>Error History</h2>
    <div id="@ViewIds.AdminErrorFeedWrapper">
        @await Html.PartialAsync("_AdminErrorFeed", Model)
    </div>
</div>