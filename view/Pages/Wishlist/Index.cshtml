@page
@model WishlistModel
@{
    ViewData["Title"] = "Wishlist";
}

<style>
    .header-wrapper {
        display: flex;
        flex-direction: row;
        justify-content: space-between;
        align-items: end;
    }
</style>
<div>
    <div class="header-wrapper">
        <h1>Wishlist</h1>
        <button hx-get="/Wishlist?handler=add" hx-target="#@ViewIds.WishlistAddWrapper">Add</button>
    </div>
    <div id="@ViewIds.WishlistList">
        @await Html.PartialAsync("_WishlistList", Model)
    </div>
    <div id="@ViewIds.WishlistAddWrapper"></div>
    <div id="@ViewIds.WishlistEditWrapper"></div>
</div>