@page
@using core
@using core.Models.ServiceModels
@model IndexModel
@{
    ViewData["Title"] = "Recipes";
}

<style>
    .recipe-list-header {
        display: flex;
        align-items: end;
    }
    
    .recipe-header-item {
        margin: var(--large) var(--small) var(--small) 0;
    }

    .recipe-list-container {
        width: 100%;
    }
</style>
<div>
    <div class="recipe-list-header" hx-include=".recipe-header-item">
        <select
            class="recipe-header-item"
            id="order"
            name="order"
            hx-get="/Index?handler=WithFilter"
            hx-target="#recipe-list-container">
            <option value="">Select Order</option>
            <option value="@SortStrategies.Favorites">
                @SortStrategies.Favorites
            </option>
            <option value="@SortStrategies.Newest">
                @SortStrategies.Newest
            </option>
            <option value="@SortStrategies.Oldest">
                @SortStrategies.Oldest
            </option>
            <option value="@SortStrategies.Alphabetical">
                @SortStrategies.Alphabetical
            </option>
        </select>
        <select
            class="recipe-header-item"
            id="category"
            name="category"
            hx-get="/Index?handler=WithFilter"
            hx-target="#recipe-list-container">
            <option value="">Select Category</option>
            <option value="@Categories.Entree">@Categories.Entree</option>
            <option value="@Categories.Side">@Categories.Side</option>
            <option value="@Categories.Desert">@Categories.Desert</option>
        </select>
    </div>
    <div id="recipe-list-container" class="recipe-list-container">
        @await Html.PartialAsync("_RecipeList", Model)
    </div>
</div>
